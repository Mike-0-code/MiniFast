<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>ThumbFast - Miniatura Rápida</title>
    <!-- Fabric.js para manejo de canvas y objetos -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.0/fabric.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none; /* Evita selección de texto en la UI, pero no afecta inputs */
        }

        body {
            background-color: #0a0a0a;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            color: #e0e0e0;
        }

        /* Barra superior */
        .top-bar {
            background-color: #111111;
            padding: 8px 16px;
            display: flex;
            gap: 20px;
            border-bottom: 1px solid #2a2a2a;
            z-index: 10;
        }

        .tool-btn {
            background: none;
            border: none;
            color: #b0b0b0;
            font-size: 24px;
            cursor: pointer;
            padding: 6px 12px;
            border-radius: 8px;
            transition: all 0.2s ease;
            font-weight: 500;
        }

        .tool-btn:hover {
            background-color: #2a2a2a;
            color: #ffffff;
        }

        /* Layout principal: panel izquierdo + canvas */
        .main-layout {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        /* Panel izquierdo de personalización */
        .left-panel {
            width: 260px;
            background-color: #141414;
            border-right: 1px solid #2a2a2a;
            padding: 20px 16px;
            display: flex;
            flex-direction: column;
            gap: 24px;
            overflow-y: auto;
            z-index: 5;
        }

        .panel-section {
            border-bottom: 1px solid #2a2a2a;
            padding-bottom: 16px;
        }

        .panel-section h3 {
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 12px;
            color: #cccccc;
            letter-spacing: 0.5px;
        }

        .control-group {
            margin-bottom: 12px;
        }

        .control-group label {
            display: block;
            font-size: 12px;
            margin-bottom: 6px;
            color: #aaa;
        }

        select, input[type="color"], input[type="number"] {
            background-color: #2a2a2a;
            border: 1px solid #3a3a3a;
            color: #e0e0e0;
            padding: 6px 8px;
            border-radius: 6px;
            width: 100%;
            font-size: 13px;
        }

        .shape-type-buttons {
            display: flex;
            gap: 8px;
            margin-top: 6px;
        }

        .shape-type-btn {
            background-color: #2a2a2a;
            border: 1px solid #3a3a3a;
            color: #ccc;
            padding: 6px 0;
            border-radius: 6px;
            cursor: pointer;
            flex: 1;
            text-align: center;
            font-size: 18px;
        }

        .shape-type-btn.active {
            background-color: #3a6ea5;
            border-color: #5a8ec5;
            color: white;
        }

        .font-preview {
            font-size: 14px;
            padding: 4px;
        }

        .slider {
            width: 100%;
            cursor: pointer;
            background: #2a2a2a;
            accent-color: #3a6ea5;
        }

        .status-text {
            font-size: 12px;
            color: #888;
            text-align: center;
            margin-top: 16px;
            font-style: italic;
        }

        /* Contenedor del canvas centrado */
        .canvas-container-wrapper {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #0a0a0a;
            position: relative;
            overflow: hidden;
        }

        .canvas-wrapper {
            position: relative;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            transition: all 0.1s ease;
        }

        canvas {
            display: block;
            cursor: crosshair;
        }

        /* Placeholder del + (se muestra cuando no hay imagen) */
        .placeholder-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            pointer-events: none;
            background-color: #2a2a2a;
            color: #555;
            font-size: 48px;
            font-weight: 100;
            border: 1px dashed #444;
        }

        /* Ocultar placeholder cuando hay imagen */
        .has-image .placeholder-overlay {
            display: none;
        }

        /* Botón de descarga */
        .download-btn {
            background-color: #2a6e3a;
            color: white;
            border: none;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 14px;
            cursor: pointer;
            transition: 0.2s;
        }
        .download-btn:hover {
            background-color: #3a8e4a;
        }
    </style>
</head>
<body>

<div class="top-bar">
    <button class="tool-btn" id="tool-text" title="Agregar texto (T)">T</button>
    <button class="tool-btn" id="tool-shape" title="Agregar forma (Rectángulo / Círculo / Triángulo)">⬛</button>
    <button class="tool-btn" id="tool-bg" title="Color de fondo sólido">🎨</button>
    <button class="tool-btn" id="tool-preset" title="Presets de tamaño">📏</button>
    <button class="tool-btn download-btn" id="tool-download" title="Descargar PNG">💾</button>
</div>

<div class="main-layout">
    <!-- Panel izquierdo de personalización -->
    <div class="left-panel" id="left-panel">
        <div class="panel-section">
            <h3>📝 Texto</h3>
            <div class="control-group">
                <label>Fuente</label>
                <select id="font-family">
                    <option value="Arial">Arial</option>
                    <option value="Helvetica">Helvetica</option>
                    <option value="Times New Roman">Times New Roman</option>
                    <option value="Courier New">Courier New</option>
                    <option value="Georgia">Georgia</option>
                    <option value="Verdana">Verdana</option>
                    <option value="Impact">Impact</option>
                    <option value="Comic Sans MS">Comic Sans MS</option>
                </select>
            </div>
            <div class="control-group">
                <label>Tamaño (px)</label>
                <input type="number" id="font-size" value="48" min="12" max="200" step="2">
            </div>
            <div class="control-group">
                <label>Color</label>
                <input type="color" id="text-color" value="#ffffff">
            </div>
            <div class="control-group">
                <label>Alineación</label>
                <select id="text-align">
                    <option value="left">Izquierda</option>
                    <option value="center">Centro</option>
                    <option value="right">Derecha</option>
                </select>
            </div>
        </div>

        <div class="panel-section">
            <h3>🔷 Forma</h3>
            <div class="control-group">
                <label>Tipo</label>
                <div class="shape-type-buttons" id="shape-type-selector">
                    <div class="shape-type-btn" data-shape="rect">■</div>
                    <div class="shape-type-btn" data-shape="circle">●</div>
                    <div class="shape-type-btn" data-shape="triangle">▲</div>
                </div>
            </div>
            <div class="control-group">
                <label>Relleno</label>
                <input type="color" id="shape-fill" value="#ff5555">
            </div>
            <div class="control-group">
                <label>Borde</label>
                <input type="color" id="stroke-color" value="#ffffff">
            </div>
            <div class="control-group">
                <label>Grosor borde (px)</label>
                <input type="number" id="stroke-width" value="3" min="1" max="15">
            </div>
        </div>

        <div class="panel-section">
            <h3>🎨 Fondo Lienzo</h3>
            <div class="control-group">
                <input type="color" id="canvas-bg-color" value="#2a2a2a">
                <button id="apply-bg-btn" style="margin-top:8px; width:100%; background:#2a2a2a; border:1px solid #3a3a3a; color:white; padding:6px; border-radius:6px;">Aplicar fondo</button>
            </div>
        </div>
        <div class="status-text" id="status-msg">
            Selecciona un elemento<br>para personalizar
        </div>
    </div>

    <!-- Área del canvas -->
    <div class="canvas-container-wrapper" id="canvas-container">
        <div class="canvas-wrapper" id="canvas-wrapper">
            <canvas id="canvas" width="800" height="450" style="background-color:#2a2a2a;"></canvas>
            <div class="placeholder-overlay" id="placeholder">+</div>
        </div>
    </div>
</div>

<script>
    // Configuración inicial del canvas
    const canvas = new fabric.Canvas('canvas');
    let currentSelectedObject = null;
    let hasImage = false;

    // Inicializar con fondo gris
    canvas.setBackgroundColor('#2a2a2a', canvas.renderAll.bind(canvas));

    // ---- ZOOM con rueda del mouse (como la gente espera) ----
    const container = document.getElementById('canvas-container');
    let zoomLevel = 1;
    canvas.on('mouse:wheel', function(opt) {
        const delta = opt.e.deltaY;
        let zoom = zoomLevel;
        zoom *= 0.999 ** delta;
        if (zoom > 5) zoom = 5;
        if (zoom < 0.2) zoom = 0.2;
        canvas.setZoom(zoom);
        zoomLevel = zoom;
        opt.e.preventDefault();
        opt.e.stopPropagation();
    });

    // Función para agregar imagen
    function addImageFromFile(file) {
        const reader = new FileReader();
        reader.onload = function(event) {
            fabric.Image.fromURL(event.target.result, function(img) {
                // Escalar imagen para que entre en el canvas manteniendo proporción
                const maxWidth = canvas.width * 0.9;
                const maxHeight = canvas.height * 0.9;
                let scale = 1;
                if (img.width > maxWidth) scale = maxWidth / img.width;
                if (img.height * scale > maxHeight) scale = maxHeight / img.height;
                img.scale(scale);
                img.set({
                    left: (canvas.width - img.width * scale) / 2,
                    top: (canvas.height - img.height * scale) / 2,
                    selectable: true,
                    hasControls: true,
                    hasBorders: true
                });
                canvas.add(img);
                canvas.setActiveObject(img);
                hasImage = true;
                document.getElementById('canvas-wrapper').classList.add('has-image');
                canvas.renderAll();
                updatePanelForObject(img);
            });
        };
        reader.readAsDataURL(file);
    }

    // Click en el placeholder (o arrastrar)
    const placeholderDiv = document.getElementById('placeholder');
    const canvasWrapper = document.getElementById('canvas-wrapper');
    canvasWrapper.addEventListener('click', (e) => {
        if (!hasImage && e.target === placeholderDiv || placeholderDiv.contains(e.target)) {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'image/*';
            input.onchange = (e2) => {
                if (e2.target.files[0]) addImageFromFile(e2.target.files[0]);
            };
            input.click();
        }
    });

    // Arrastrar imagen desde escritorio
    const containerDiv = document.getElementById('canvas-container');
    containerDiv.addEventListener('dragover', (e) => {
        e.preventDefault();
    });
    containerDiv.addEventListener('drop', (e) => {
        e.preventDefault();
        const file = e.dataTransfer.files[0];
        if (file && file.type.startsWith('image/')) {
            addImageFromFile(file);
        }
    });

    // ----- Herramientas -----
    document.getElementById('tool-text').addEventListener('click', () => {
        if (!hasImage) {
            alert("Primero agrega una imagen de fondo.");
            return;
        }
        const text = new fabric.IText('Texto', {
            left: canvas.width/2 - 50,
            top: canvas.height/2 - 20,
            fontFamily: document.getElementById('font-family').value,
            fontSize: parseInt(document.getElementById('font-size').value),
            fill: document.getElementById('text-color').value,
            textAlign: document.getElementById('text-align').value,
            hasControls: true,
            padding: 5
        });
        canvas.add(text);
        canvas.setActiveObject(text);
        canvas.renderAll();
        updatePanelForObject(text);
    });

    // Crear forma según tipo actual
    let currentShapeType = 'rect'; // rect, circle, triangle
    document.querySelectorAll('.shape-type-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.shape-type-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentShapeType = btn.getAttribute('data-shape');
            // Si hay una forma seleccionada, podemos cambiar su tipo? (opcional)
            if (currentSelectedObject && (currentSelectedObject.customType === 'shape')) {
                replaceShape(currentSelectedObject);
            }
        });
    });

    function createShape(type, left, top, fill, stroke, strokeWidth) {
        let shape;
        const size = 80;
        switch(type) {
            case 'rect':
                shape = new fabric.Rect({
                    width: size, height: size, fill: fill, stroke: stroke, strokeWidth: strokeWidth,
                    left: left, top: top, originX: 'center', originY: 'center'
                });
                break;
            case 'circle':
                shape = new fabric.Circle({
                    radius: size/2, fill: fill, stroke: stroke, strokeWidth: strokeWidth,
                    left: left, top: top, originX: 'center', originY: 'center'
                });
                break;
            case 'triangle':
                shape = new fabric.Triangle({
                    width: size, height: size, fill: fill, stroke: stroke, strokeWidth: strokeWidth,
                    left: left, top: top, originX: 'center', originY: 'center'
                });
                break;
        }
        shape.customType = 'shape';
        return shape;
    }

    function replaceShape(oldShape) {
        const newShape = createShape(currentShapeType, oldShape.left, oldShape.top, 
                                    oldShape.fill, oldShape.stroke, oldShape.strokeWidth);
        canvas.remove(oldShape);
        canvas.add(newShape);
        canvas.setActiveObject(newShape);
        canvas.renderAll();
        updatePanelForObject(newShape);
    }

    document.getElementById('tool-shape').addEventListener('click', () => {
        if (!hasImage) {
            alert("Primero agrega una imagen de fondo.");
            return;
        }
        const fill = document.getElementById('shape-fill').value;
        const stroke = document.getElementById('stroke-color').value;
        const strokeWidth = parseInt(document.getElementById('stroke-width').value);
        const shape = createShape(currentShapeType, canvas.width/2, canvas.height/2, fill, stroke, strokeWidth);
        canvas.add(shape);
        canvas.setActiveObject(shape);
        canvas.renderAll();
        updatePanelForObject(shape);
    });

    // Fondo de lienzo
    document.getElementById('apply-bg-btn').addEventListener('click', () => {
        const color = document.getElementById('canvas-bg-color').value;
        canvas.setBackgroundColor(color, canvas.renderAll.bind(canvas));
    });

    // Presets de tamaño
    document.getElementById('tool-preset').addEventListener('click', () => {
        const preset = prompt("Elige preset: YouTube (1280x720), Twitter (1200x675), Instagram (1080x1080)", "YouTube");
        let width, height;
        if (preset.toLowerCase().includes('youtube')) { width = 1280; height = 720; }
        else if (preset.toLowerCase().includes('twitter')) { width = 1200; height = 675; }
        else if (preset.toLowerCase().includes('instagram')) { width = 1080; height = 1080; }
        else { alert("No reconocido. Usando YouTube"); width = 1280; height = 720; }
        
        canvas.setWidth(width);
        canvas.setHeight(height);
        canvas.renderAll();
        // Ajustar contenedor visual (solo estilo)
        document.querySelector('.canvas-wrapper').style.width = Math.min(width, window.innerWidth-280) + 'px';
        canvas.renderAll();
    });

    // Descargar
    document.getElementById('tool-download').addEventListener('click', () => {
        const link = document.createElement('a');
        link.download = 'miniatura.png';
        link.href = canvas.toDataURL({ format: 'png', quality: 1 });
        link.click();
    });

    // ---- Actualizar panel cuando se selecciona un objeto ----
    function updatePanelForObject(obj) {
        if (!obj) {
            document.getElementById('status-msg').innerHTML = "Selecciona un elemento<br>para personalizar";
            return;
        }
        currentSelectedObject = obj;
        document.getElementById('status-msg').innerHTML = `Editando: ${obj.customType === 'shape' ? 'Forma' : 'Texto'}`;
        
        if (obj.isType && (obj.isType('i-text') || obj.isType('text'))) {
            // Texto
            document.getElementById('font-family').value = obj.fontFamily || 'Arial';
            document.getElementById('font-size').value = obj.fontSize || 48;
            document.getElementById('text-color').value = obj.fill || '#ffffff';
            document.getElementById('text-align').value = obj.textAlign || 'center';
        } 
        else if (obj.customType === 'shape') {
            // Forma
            document.getElementById('shape-fill').value = obj.fill || '#ff5555';
            document.getElementById('stroke-color').value = obj.stroke || '#ffffff';
            document.getElementById('stroke-width').value = obj.strokeWidth || 3;
            // Actualizar botón activo según tipo
            let shapeType = 'rect';
            if (obj.get('radius')) shapeType = 'circle';
            else if (obj.get('width') && obj.get('height') && obj.type === 'triangle') shapeType = 'triangle';
            else shapeType = 'rect';
            document.querySelectorAll('.shape-type-btn').forEach(btn => {
                btn.classList.remove('active');
                if (btn.getAttribute('data-shape') === shapeType) btn.classList.add('active');
            });
            currentShapeType = shapeType;
        }
    }

    // Evento de selección en canvas
    canvas.on('selection:created', (e) => updatePanelForObject(e.selected[0]));
    canvas.on('selection:updated', (e) => updatePanelForObject(e.selected[0]));
    canvas.on('selection:cleared', () => updatePanelForObject(null));

    // Modificar propiedades desde los controles
    document.getElementById('font-family').addEventListener('change', () => {
        if (currentSelectedObject && (currentSelectedObject.isType('i-text') || currentSelectedObject.isType('text'))) {
            currentSelectedObject.set('fontFamily', document.getElementById('font-family').value);
            canvas.renderAll();
        }
    });
    document.getElementById('font-size').addEventListener('change', () => {
        if (currentSelectedObject && (currentSelectedObject.isType('i-text') || currentSelectedObject.isType('text'))) {
            currentSelectedObject.set('fontSize', parseInt(document.getElementById('font-size').value));
            canvas.renderAll();
        }
    });
    document.getElementById('text-color').addEventListener('change', () => {
        if (currentSelectedObject && (currentSelectedObject.isType('i-text') || currentSelectedObject.isType('text'))) {
            currentSelectedObject.set('fill', document.getElementById('text-color').value);
            canvas.renderAll();
        }
    });
    document.getElementById('text-align').addEventListener('change', () => {
        if (currentSelectedObject && (currentSelectedObject.isType('i-text') || currentSelectedObject.isType('text'))) {
            currentSelectedObject.set('textAlign', document.getElementById('text-align').value);
            canvas.renderAll();
        }
    });
    document.getElementById('shape-fill').addEventListener('change', () => {
        if (currentSelectedObject && currentSelectedObject.customType === 'shape') {
            currentSelectedObject.set('fill', document.getElementById('shape-fill').value);
            canvas.renderAll();
        }
    });
    document.getElementById('stroke-color').addEventListener('change', () => {
        if (currentSelectedObject && currentSelectedObject.customType === 'shape') {
            currentSelectedObject.set('stroke', document.getElementById('stroke-color').value);
            canvas.renderAll();
        }
    });
    document.getElementById('stroke-width').addEventListener('change', () => {
        if (currentSelectedObject && currentSelectedObject.customType === 'shape') {
            currentSelectedObject.set('strokeWidth', parseInt(document.getElementById('stroke-width').value));
            canvas.renderAll();
        }
    });

    // Soporte teclado: eliminar
    window.addEventListener('keydown', (e) => {
        if (e.key === 'Delete' && currentSelectedObject) {
            canvas.remove(currentSelectedObject);
            canvas.renderAll();
            updatePanelForObject(null);
        }
        // Ctrl+Z deshacer (fabric soporta historia)
        if (e.ctrlKey && e.key === 'z') {
            e.preventDefault();
            // implementación simple
        }
    });

    // Inicializar: placeholder activo
    canvas.renderAll();
</script>
</body>
</html>
